# Elevenlabs API key
# Get this from your Elevenlabs dashboard: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Agent/Assistant ID (optional)
# If you want to associate the knowledge base with a specific assistant
ELEVENLABS_ASSISTANT_ID=your_assistant_id_here

# Scraping configuration
# How often to check for updates (in hours)
UPDATE_INTERVAL=24 